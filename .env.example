# =========================================================
# 學生選填系統 — 環境變數範本
# 複製此檔案為 .env，填入真實值後再啟動 docker compose
# =========================================================

# === 資料庫 ===
# Docker Compose 內部預設值（db service 名稱）
DATABASE_URL=postgresql://postgres:postgres@db:5432/academy
# Docker 本地使用 prefer；外部 managed DB（如 Render）使用 require
DB_SSLMODE=prefer
# PostgreSQL container 帳號密碼（與 DATABASE_URL 保持一致）
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=academy

# === 安全性 ===
# JWT 簽名金鑰，務必替換為隨機字串（至少 32 字元）
SECRET_KEY=change-me-in-production
# 系統管理員初始帳號密碼
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# === 應用程式 ===
# 選填截止時間（格式：YYYY-MM-DD HH:MM:SS，Asia/Taipei）
DEADLINE_DATE=2026-05-04 23:59:59+0800

# === 郵件 — Google Workspace SMTP Relay ===
# 使用前須在 Google Admin Console > Apps > Gmail > Routing > SMTP Relay Service 啟用 SMTP Auth
SMTP_HOST=smtp-relay.gmail.com
SMTP_PORT=587
# 寄件帳號（Google Workspace 網域帳號，如 system@school.edu.tw）
SMTP_USER=your-account@school.edu.tw
# 帳號密碼（建議使用 App Password）
SMTP_PASSWORD=your-smtp-password
# 寄件者名稱
SMTP_FROM_NAME=

# === Cloudflare Tunnel ===
# 從 Cloudflare Zero Trust > Networks > Tunnels 建立後取得
TUNNEL_TOKEN=your-tunnel-token-here
# 傳輸協定：auto（預設，優先 QUIC，降回 HTTP/2）、quic、http2
TUNNEL_TRANSPORT_PROTOCOL=auto

# === 前端設定 ===
# API 基礎 URL，空字串代表相對路徑（nginx 同域 proxy，無需設定）
# 若 frontend 與 backend 不同域才需設定，例如：https://api.school.edu.tw
API_BASE_URL=

# === FastAPI 設定 ===
# 若今天到 production 環境，要設定為 "prod"
# 否則都屬於 development 環境
FASTAPI_APP_ENVIRONMENT=
PROD_DOMAIN=